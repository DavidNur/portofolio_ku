---

---

<section class="relative min-h-[90vh] w-full px-6 pt-12 md:px-12 lg:px-24">
  <!-- Doodles/Icons -->
  <div class="absolute right-[20%] top-[10%] opacity-20 md:opacity-100">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="64"
      height="64"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="text-text"
      ><path
        d="M15 6v12a3 3 0 1 0 3-3H6a3 3 0 1 0 3 3V6a3 3 0 1 0-3 3h12a3 3 0 1 0-3-3"
      ></path><circle cx="9" cy="9" r="2"></circle></svg
    >
  </div>
  <div class="absolute left-[10%] top-[5%] opacity-20 md:opacity-100">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="48"
      height="48"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="text-text"
      ><rect width="16" height="12" x="2" y="8" rx="2"></rect><path
        d="M22 17V9a2 2 0 0 0-2-2h-3"></path><path d="M15 13a3 3 0 1 0-3-3"
      ></path></svg
    >
  </div>

  <div class="grid grid-cols-1 gap-8 lg:grid-cols-2">
    <!-- Left Content -->
    <div class="flex flex-col justify-center pt-20">
      <div class="relative">
        <span class="absolute -top-12 left-0 text-6xl font-display text-primary"
          >"</span
        >
        <h1
          class="font-display text-[7rem] leading-[0.8] tracking-tighter text-text md:text-[10rem]"
        >
          PORTO<br />FOLIO<span class="text-primary">.</span>
        </h1>
      </div>

      <div class="mt-8 flex items-center gap-4">
        <div
          class="bg-primary px-6 py-2 font-display text-xl uppercase brutal-border"
        >
          Web Developer
        </div>
        <div class="hidden h-[2px] flex-grow bg-text md:block"></div>
      </div>

      <div class="mt-12 flex items-center gap-4">
        <div
          class="flex h-12 w-12 items-center justify-center rounded-full border-2 border-text font-bold"
        >
          &gt;
        </div>
        <span class="font-display text-2xl uppercase">David Nur Hidayat</span>
      </div>
    </div>

    <!-- Right Content (Image) -->
    <div class="relative flex items-center justify-center lg:justify-end">
      <!-- Big "01" background -->

      <div
        class="relative h-[500px] w-full max-w-[400px] md:h-[600px] md:max-w-[450px]"
      >
        <!-- Yellow Backdrop circle -->
        <div
          class="absolute bottom-0 right-0 h-[90%] w-full rounded-b-full bg-primary -z-0"
        >
        </div>

        <!-- Profile Image Placeholder (Using a high-quality stylized male photo) -->
        <img
          src="\profile1.jpg"
          alt="Randy Fahmi"
          class="relative z-10 h-full w-full object-cover grayscale"
          style="mask-image: linear-gradient(to bottom, black 80%, transparent 100%);"
        />

        <!-- Tag -->
        <div
          class="absolute bottom-10 right-0 z-20 max-w-[150px] text-right font-accent italic leading-tight text-text"
        >
          <p class="text-sm font-light uppercase tracking-widest">
            Selected Best
          </p>
          <p class="text-lg font-bold">Web Developer</p>
        </div>
      </div>

      <!-- Vertical Sidebar Text -->
      <div
        class="absolute -right-8 top-1/2 -translate-y-1/2 rotate-90 whitespace-nowrap font-accent text-xs font-bold uppercase tracking-[0.2em] text-text/40 md:-right-12"
      >
        RANDY &copy; 2025
      </div>
    </div>
  </div>
</section>
