---
import { Image } from "astro:assets";
import profileImg from "../assets/profile3.png";
---

<section
  id="home"
  class="relative min-h-screen flex flex-col pt-24 overflow-hidden"
>
  <!-- Social Sidebar (Vertical) -->
  <div
    class="absolute left-8 top-1/2 -translate-y-1/2 hidden md:flex flex-col items-center gap-8 z-20"
  >
    <div class="w-[1px] h-16 bg-[#ff2b2b]"></div>
    <div
      class="flex flex-col gap-6 text-[10px] uppercase tracking-[0.3em] font-bold opacity-50"
    >
      <a
        href="https://mail.google.com/mail/?view=cm&fs=1&to=davidhidayat.nh11@gmail.com"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-[#ff2b2b] transition-colors -rotate-90 origin-center py-2"
        ><svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="icon icon-tabler icons-tabler-outline icon-tabler-brand-gmail"
        >
          <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
          <path d="M16 20h3a1 1 0 0 0 1 -1v-14a1 1 0 0 0 -1 -1h-3v16"></path>
          <path d="M5 20h3v-16h-3a1 1 0 0 0 -1 1v14a1 1 0 0 0 1 1"></path>
          <path d="M16 4l-4 4l-4 -4"></path>
          <path d="M4 6.5l8 7.5l8 -7.5"></path>
        </svg></a
      >
      <a
        href="https://www.facebook.com/davidnur.hidayat.73"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-[#ff2b2b] transition-colors -rotate-90 origin-center py-2"
        ><svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="icon icon-tabler icons-tabler-outline icon-tabler-brand-facebook"
        >
          <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
          <path
            d="M7 10v4h3v7h4v-7h3l1 -4h-4v-2a1 1 0 0 1 1 -1h3v-4h-3a5 5 0 0 0 -5 5v2h-3"
          ></path>
        </svg></a
      >
      <a
        href="https://www.instagram.com/dnhidayat11/"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-[#ff2b2b] transition-colors -rotate-90 origin-center py-2"
        ><svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="icon icon-tabler icons-tabler-outline icon-tabler-brand-instagram"
        >
          <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
          <path
            d="M4 8a4 4 0 0 1 4 -4h8a4 4 0 0 1 4 4v8a4 4 0 0 1 -4 4h-8a4 4 0 0 1 -4 -4l0 -8"
          ></path>
          <path d="M9 12a3 3 0 1 0 6 0a3 3 0 0 0 -6 0"></path>
          <path d="M16.5 7.5v.01"></path>
        </svg></a
      >
      <a
        href="https://www.linkedin.com/in/david-nur-hidayat-09944a377/"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-[#ff2b2b] transition-colors -rotate-90 origin-center py-2"
        ><svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="icon icon-tabler icons-tabler-outline icon-tabler-brand-linkedin"
        >
          <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
          <path d="M8 11v5"></path>
          <path d="M8 8v.01"></path>
          <path d="M12 16v-5"></path>
          <path d="M16 16v-3a2 2 0 1 0 -4 0"></path>
          <path
            d="M3 7a4 4 0 0 1 4 -4h10a4 4 0 0 1 4 4v10a4 4 0 0 1 -4 4h-10a4 4 0 0 1 -4 -4l0 -10"
          ></path>
        </svg></a
      >
    </div>
    <div class="w-[1px] h-16 bg-black/10 dark:bg-white/10"></div>
  </div>

  <!-- Main Content -->
  <div class="flex-1 flex max-w-7xl w-full mx-auto px-16 relative">
    <!-- Decorative Background Text -->
    <div
      class="absolute right-0 bottom-20 text-[240px] font-black text-black/[0.05] dark:text-white/[0.05] leading-none select-none pointer-events-none z-0 tracking-tighter"
    >
      DNH.
    </div>

    <div
      class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-center w-full relative z-10"
    >
      <!-- Left Content -->
      <div class="lg:col-span-3 reveal">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-12 h-[1px] bg-[#ff2b2b]"></div>
          <p
            class="text-[#ff2b2b] font-bold tracking-[0.3em] uppercase text-[11px]"
          >
            BUILDING MODERN WEBSITES
          </p>
        </div>

        <h1
          class="text-7xl md:text-[100px] font-black tracking-tighter leading-[0.9] mb-8 dark:text-white text-black"
        >
          I'M
          <span class="text-[#ff2b2b]">DAVID,</span>
          <br />
          A WEB
          <br />
          DEVELOPER
        </h1>

        <p class="text-lg opacity-60 max-w-md mb-10 leading-relaxed italic">
          I create modern and responsive websites that help ideas grow into
          functional digital experiences with clean design and smooth user
          experience.
        </p>

        <div class="flex flex-wrap gap-6">
          <a
            href="#projects"
            class="px-10 py-4 bg-[#ff2b2b] text-white font-bold uppercase tracking-widest text-xs hover:shadow-[0_0_30px_rgba(255,43,43,0.3)] transition-all"
          >
            View Projects
          </a>
          <a
            href="#contact"
            class="px-10 py-4 border border-black/20 dark:border-white/20 text-black dark:text-white font-bold uppercase tracking-widest text-xs hover:bg-black/5 dark:hover:bg-white/5 transition-all"
          >
            Let's Talk
          </a>
        </div>
      </div>

      <!-- Right Image/Visual -->
      <div
        class="lg:col-span-2 relative flex justify-center lg:justify-end reveal delay-200"
      >
        <div
          class="w-full max-w-[400px] aspect-[3/4] relative z-10 overflow-hidden border border-black/5 dark:border-white/5 shadow-2xl group"
        >
          <div
            class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent z-20"
          >
          </div>
          <Image
            src={profileImg}
            format="webp"
            quality={80}
            alt="David Nur Hidayat Portfolio Portrait"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          />
          <div class="absolute bottom-8 left-8 z-30">
            <p
              class="text-[10px] uppercase tracking-[0.2em] font-bold opacity-50 mb-1 text-white"
            >
              Based in
            </p>
            <p class="text-lg font-bold text-white">Sukoharjo, Indonesia</p>
          </div>
          <!-- Geometric Decor -->
          <div
            class="absolute top-8 right-8 w-16 h-16 border-t border-r border-[#ff2b2b]/40 z-30 transition-all duration-500 group-hover:scale-110"
          >
          </div>
        </div>
        <!-- Glow Effect Behind Image -->
        <div
          class="absolute w-[120%] h-[120%] bg-[#ff2b2b]/10 rounded-full blur-[100px] -z-0 translate-x-10 -translate-y-10 group-hover:scale-110 transition-transform duration-700"
        >
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Info Rail -->
  <div
    class="h-24 w-full px-16 flex items-center justify-between border-t border-black/[0.03] dark:border-white/[0.05] z-20 bg-white/50 dark:bg-black/50 backdrop-blur-md"
  >
    <div class="flex items-center gap-12">
      <div class="flex flex-col">
        <span
          class="text-[10px] uppercase tracking-widest text-[#ff2b2b] font-bold mb-1"
          >Experience</span
        >
        <span class="text-xl font-bold dark:text-white text-black"
          >&#177;1 Years</span
        >
      </div>
      <div class="flex flex-col">
        <span
          class="text-[10px] uppercase tracking-widest text-[#ff2b2b] font-bold mb-1"
          >Clients</span
        >
        <span class="text-xl font-bold dark:text-white text-black"
          >5+ Project</span
        >
      </div>
      <div class="flex hidden md:flex flex-col">
        <span
          class="text-[10px] uppercase tracking-widest text-[#ff2b2b] font-bold mb-1"
          >Focus</span
        >
        <span class="text-xl font-bold dark:text-white text-black"
          >Modern Web</span
        >
      </div>
    </div>

    <div class="flex items-center gap-4">
      <span
        class="text-[10px] uppercase tracking-widest font-bold opacity-30 dark:text-white text-black"
        >Scroll to explore</span
      >
      <div class="w-12 h-px bg-black/20 dark:bg-white/20"></div>
      <div
        class="w-6 h-10 border-2 border-black/20 dark:border-white/20 rounded-full flex justify-center p-1"
      >
        <div class="w-1 h-2 bg-[#ff2b2b] rounded-full animate-bounce"></div>
      </div>
    </div>
  </div>
</section>
