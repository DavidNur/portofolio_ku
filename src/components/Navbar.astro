---
const navLinks = [
  "Home",
  "About",
  "Services",
  "Works",
  "Clients",
  "Blog",
  "Contact",
];
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 w-full z-50 transition-all duration-300 py-6 bg-transparent"
>
  <div class="max-w-7xl mx-auto px-6 flex justify-between items-center">
    <a
      href="#"
      class="text-xl font-display font-bold tracking-widest text-white transition-colors duration-300"
      id="nav-logo"
    >
      HIDAYAT
    </a>

    <div class="hidden md:flex space-x-8">
      {
        navLinks.map((link) => (
          <a
            href={`#${link.toLowerCase()}`}
            class="nav-link text-sm font-medium transition-colors text-white opacity-80 hover:opacity-100 relative group overflow-hidden"
          >
            {link}
            <span class="absolute bottom-0 left-0 w-full h-[2px] bg-white transition-transform duration-300 translate-x-[-101%] group-hover:translate-x-0" />
          </a>
        ))
      }
      <button
        id="lang-toggle"
        class="lang-btn px-4 py-2 rounded-full bg-white/10 text-white text-xs font-bold backdrop-blur transition hover:bg-white hover:text-slate-900"
      >
        EN
      </button>
    </div>
  </div>
</nav>
<div id="google_translate_element" class="hidden"></div>

<script is:inline>
  const nav = document.getElementById("main-nav");
  const logo = document.getElementById("nav-logo");
  const links = document.querySelectorAll(".nav-link");
  const underlineColors = document.querySelectorAll(".nav-link span");
  const langBtn = document.getElementById("lang-toggle");

  const updateNav = () => {
    if (window.scrollY > 50) {
      langBtn?.classList.remove("text-white", "bg-white/10");
      langBtn?.classList.add("text-slate-900", "bg-slate-100");

      nav?.classList.remove("bg-transparent", "py-6");
      nav?.classList.add(
        "bg-white/90",
        "backdrop-blur-md",
        "py-4",
        "shadow-sm",
      );

      logo?.classList.remove("text-white");
      logo?.classList.add("text-slate-900");

      links.forEach((l) => {
        l.classList.remove("text-white", "opacity-80");
        l.classList.add("text-slate-700", "opacity-100");
      });

      underlineColors.forEach((s) => {
        s.classList.remove("bg-white");
        s.classList.add("bg-slate-900");
      });
    } else {
      langBtn?.classList.add("text-white", "bg-white/10");
      langBtn?.classList.remove("text-slate-900", "bg-slate-100");

      nav?.classList.add("bg-transparent", "py-6");
      nav?.classList.remove(
        "bg-white/90",
        "backdrop-blur-md",
        "py-4",
        "shadow-sm",
      );

      logo?.classList.add("text-white");
      logo?.classList.remove("text-slate-900");

      links.forEach((l) => {
        l.classList.add("text-white", "opacity-80");
        l.classList.remove("text-slate-700", "opacity-100");
      });

      underlineColors.forEach((s) => {
        s.classList.add("bg-white");
        s.classList.remove("bg-slate-900");
      });
    }
  };

  window.addEventListener("scroll", updateNav);
  updateNav();

  window.googleTranslateElementInit = function () {
    new google.translate.TranslateElement(
      {
        pageLanguage: "id",
        includedLanguages: "id,en",
        autoDisplay: false,
      },
      "google_translate_element",
    );
  };

  function setLanguage(lang) {
    const timer = setInterval(() => {
      const select = document.querySelector(".goog-te-combo");

      if (select) {
        select.value = lang;
        select.dispatchEvent(new Event("change"));
        localStorage.setItem("lang", lang);
        clearInterval(timer);
      }
    }, 300);
  }

  langBtn?.addEventListener("click", () => {
    const currentLang = localStorage.getItem("lang") || "id";
    const nextLang = currentLang === "id" ? "en" : "id";

    setLanguage(nextLang);
    langBtn.textContent = nextLang === "id" ? "EN" : "ID";
  });

  setTimeout(() => {
    const savedLang = localStorage.getItem("lang");

    if (savedLang && savedLang !== "id") {
      setLanguage(savedLang);
      if (langBtn) langBtn.textContent = "ID";
    }
  }, 1000);
</script>

<script
  is:inline
  src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"
></script>

<script
  is:inline
  src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"
></script>
