---
import ThemeToggle from "./ThemeToggle.astro";

const navItems = [
  { name: "Home", href: "#home" },
  { name: "About", href: "#about" },
  { name: "Projects", href: "#projects" },
  { name: "Experience", href: "#experience" },
  { name: "Contact", href: "#contact" },
];
---

<nav
  id="navbar"
  class="fixed top-0 left-0 w-full z-50 transition-all duration-300 h-24 flex items-center border-b border-black/[0.03] dark:border-white/[0.05] backdrop-blur-xl"
>
  <div class="max-w-7xl w-full mx-auto px-16 flex items-center justify-between">
    <!-- Logo -->
    <a
      href="#home"
      class="text-2xl font-display font-black tracking-tighter group flex items-center gap-2"
    >
      <div
        class="w-8 h-8 bg-[#ff2b2b] rounded-sm flex items-center justify-center text-black text-lg"
      >
        D
      </div>
      <span class="dark:text-white text-black uppercase"
        >DAVID<span class="text-[#ff2b2b]">.</span></span
      >
    </a>

    <!-- Desktop Menu -->
    <div class="hidden md:flex items-center gap-10">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="text-[11px] font-bold uppercase tracking-[0.2em] opacity-50 hover:opacity-100 hover:text-[#ff2b2b] transition-all relative group"
          >
            {item.name}
          </a>
        ))
      }
    </div>

    <!-- Right Side -->
    <div class="flex items-center gap-6">
      <ThemeToggle />

      <!-- <button
        class="hidden md:block px-6 py-2.5 bg-[#ff2b2b] text-white text-[11px] font-bold uppercase tracking-widest hover:bg-black dark:hover:bg-white dark:hover:text-black transition-all"
      >
        Hire Me
      </button> -->

      <!-- Mobile Menu Toggle -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-sm bg-black/5 dark:bg-white/5 border border-black/10 dark:border-white/10"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="dark:text-white text-black"
          ><line x1="4" x2="20" y1="12" y2="12"></line><line
            x1="4"
            x2="20"
            y1="6"
            y2="6"></line><line x1="4" x2="20" y1="18" y2="18"></line></svg
        >
      </button>
    </div>
  </div>

  <!-- Mobile Menu Overlay -->
  <div
    id="mobile-menu"
    class="fixed inset-0 bg-white dark:bg-[#050505] z-[-1] translate-x-full transition-transform duration-500 md:hidden flex flex-col items-center justify-center gap-8"
  >
    {
      navItems.map((item) => (
        <a
          href={item.href}
          class="mobile-nav-link text-3xl font-display font-bold opacity-70 hover:opacity-100 hover:text-[#ff2b2b] tracking-tight"
        >
          {item.name}
        </a>
      ))
    }
  </div>
</nav>

<script is:inline>
  const nav = document.getElementById("navbar");
  const mobileBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const mobileLinks = document.querySelectorAll(".mobile-nav-link");

  // Sticky effect
  window.addEventListener("scroll", () => {
    if (window.scrollY > 20) {
      nav?.classList.add(
        "bg-white/80",
        "dark:bg-[#050505]/80",
        "backdrop-blur-xl",
        "py-4",
        "border-b",
        "border-black/5",
        "dark:border-white/5",
      );
      nav?.classList.remove("py-6");
    } else {
      nav?.classList.remove(
        "bg-white/80",
        "dark:bg-[#050505]/80",
        "backdrop-blur-xl",
        "py-4",
        "border-b",
        "border-black/5",
        "dark:border-white/5",
      );
      nav?.classList.add("py-6");
    }
  });

  // Mobile menu toggle
  mobileBtn?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("translate-x-full");
    document.body.classList.toggle("overflow-hidden");
  });

  mobileLinks.forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu?.classList.add("translate-x-full");
      document.body.classList.remove("overflow-hidden");
    });
  });
</script>
