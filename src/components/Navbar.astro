---
const navLinks = ["Home", "About", "Contact"];
---

<header class="absolute left-0 top-0 z-50 w-full px-8 py-10 md:px-16">
  <nav class="flex items-center justify-between">
    <a
      href="/"
      class="font-bold tracking-tighter text-orange-400 uppercase text-lg"
    >
      David Nur Hidayat
    </a>

    <ul class="hidden items-center gap-16 md:flex">
      {
        navLinks.map((link) => (
          <li class="text-white text-sm font-medium">
            <a
              href={`/${link.toLowerCase()}`}
              class="hover:text-orange-400 transition-colors"
            >
              {link}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="w-10 h-5 bg-orange-400 rounded-full relative">
      <div class="absolute right-1 top-1 w-3 h-3 bg-black rounded-full"></div>
    </div>
  </nav>
</header>
