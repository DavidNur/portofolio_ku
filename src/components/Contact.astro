---

---

<section id="contact" class="py-40 relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-16 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-24">
      <div class="reveal">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-8 h-[1px] bg-[#ff2b2b]"></div>
          <h2
            class="text-[#ff2b2b] font-bold tracking-[0.3em] uppercase text-[11px]"
          >
            Get in Touch
          </h2>
        </div>
        <h3
          class="text-5xl md:text-7xl font-black tracking-tighter mb-10 dark:text-white text-black leading-tight uppercase"
        >
          LET'S CREATE <br /> SOMETHING <span class="text-[#ff2b2b]">BOLD</span
          >.
        </h3>
        <p class="text-xl opacity-60 max-w-md leading-relaxed mb-16 font-light">
          Have a vision that needs a technical edge? Let's discuss how we can
          build something exceptional.
        </p>

        <div class="space-y-10">
          <div class="flex flex-col gap-2 group">
            <p
              class="text-[10px] font-bold tracking-[0.3em] opacity-30 uppercase"
            >
              Email Address
            </p>
            <a
              href="mailto:hello@lumina.studio"
              class="text-2xl font-black tracking-tighter hover:text-[#ff2b2b] transition-all"
              >davidhidayat.nh11@gmail.com</a
            >
          </div>

          <div class="flex flex-col gap-2 group">
            <p
              class="text-[10px] font-bold tracking-[0.3em] opacity-30 uppercase"
            >
              Location
            </p>
            <p
              class="text-2xl font-black tracking-tighter dark:text-white text-black"
            >
              SUKOHARJO, INDONESIA
            </p>
          </div>
        </div>
      </div>

      <div class="reveal delay-200">
        <form
          id="contactForm"
          class="space-y-8 bg-black/[0.02] dark:bg-white/[0.02] p-10 border border-black/5 dark:border-white/5"
        >
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-3">
              <label
                class="text-[10px] font-bold tracking-[0.3em] opacity-40 uppercase"
                >Full Name</label
              >
              <input
                type="text"
                id="clientName"
                required
                placeholder="Your Name"
                class="w-full bg-transparent border-b border-black/10 dark:border-white/10 px-0 py-4 outline-none focus:border-[#ff2b2b] transition-all font-medium"
              />
            </div>
            <div class="space-y-3">
              <label
                class="text-[10px] font-bold tracking-[0.3em] opacity-40 uppercase"
                >Email</label
              >
              <input
                type="email"
                id="clientEmail"
                required
                placeholder="your_email@example.com"
                class="w-full bg-transparent border-b border-black/10 dark:border-white/10 px-0 py-4 outline-none focus:border-[#ff2b2b] transition-all font-medium"
              />
            </div>
          </div>
          <div class="space-y-3">
            <label
              class="text-[10px] font-bold tracking-[0.3em] opacity-40 uppercase"
              >Subject</label
            >
            <input
              type="text"
              id="mailSubject"
              required
              placeholder="Project Inquiry"
              class="w-full bg-transparent border-b border-black/10 dark:border-white/10 px-0 py-4 outline-none focus:border-[#ff2b2b] transition-all font-medium"
            />
          </div>
          <div class="space-y-3">
            <label
              class="text-[10px] font-bold tracking-[0.3em] opacity-40 uppercase"
              >Your Message</label
            >
            <textarea
              id="mailMessage"
              required
              placeholder="Briefly explain your goals..."
              rows="4"
              class="w-full bg-transparent border-b border-black/10 dark:border-white/10 px-0 py-4 outline-none focus:border-[#ff2b2b] transition-all font-medium resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full py-5 bg-[#ff2b2b] text-white font-black text-xs tracking-[0.3em] hover:bg-black dark:hover:bg-white dark:hover:text-black transition-all flex items-center justify-center gap-4 group"
          >
            SEND MESSAGE
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="group-hover:translate-x-2 transition-transform"
              ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
            >
          </button>
        </form>
      </div>
    </div>

    <!-- Footer Copy -->
    <div
      class="mt-40 pt-16 border-t border-black/[0.03] dark:border-white/[0.05] flex flex-col md:flex-row justify-between items-center gap-8"
    >
      <div class="flex items-center gap-6">
        <div
          class="w-8 h-8 bg-[#ff2b2b] rounded-sm flex items-center justify-center text-black font-black"
        >
          D
        </div>
        <p class="text-[10px] font-bold tracking-[0.4em] opacity-30 uppercase">
          © 2026 DAVID HIDAYAT.
        </p>
      </div>
      <div class="flex gap-10">
        <a
          href="https://www.instagram.com/dnhidayat11/"
          class="text-[10px] font-bold tracking-[0.3em] opacity-30 uppercase hover:text-[#ff2b2b] hover:opacity-100 transition-all"
          >Instagram</a
        >
        <a
          href="https://www.facebook.com/davidnur.hidayat.73"
          class="text-[10px] font-bold tracking-[0.3em] opacity-30 uppercase hover:text-[#ff2b2b] hover:opacity-100 transition-all"
          >Facebook</a
        >
        <a
          href="https://www.linkedin.com/in/david-nur-hidayat-09944a377/"
          class="text-[10px] font-bold tracking-[0.3em] opacity-30 uppercase hover:text-[#ff2b2b] hover:opacity-100 transition-all"
          >Linkedin</a
        >
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("contactForm");
  form?.addEventListener("submit", (e) => {
    e.preventDefault();

    // Ambil data inputan user
    const name = document.getElementById("clientName").value;
    const email = document.getElementById("clientEmail").value;
    const subject = document.getElementById("mailSubject").value;
    const message = document.getElementById("mailMessage").value;

    // Gabung pesan agar rapi saat masuk ke email
    const mailBody = `Hi David,\n\nMy name is ${name} (${email}).\n\n${message}`;

    // Redirect langsung ke aplikasi mail client default user
    window.location.href = `mailto:davidhidayat.nh11@gmail.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(mailBody)}`;
  });
</script>
