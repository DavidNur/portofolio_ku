---
// About.astro
---

<section id="about" class="py-24 mx-10 bg-white overflow-hidden">
  <div
    class="max-w-7xl mx-auto px-6 grid md:grid-cols-[45%_55%] gap-20 items-center"
  >
    {/* Profile Image Container */}
    <div class="reveal relative group pr-4 pb-4">
      <div
        class="absolute -bottom-6 -left-6 w-1/2 h-1/2 bg-slate-50 border-[20px] border-white -z-10 shadow-lg"
      >
      </div>
      <img
        src="/public/profile2.jpg"
        alt="Profile Portrait"
        class="w-full h-auto object-cover shadow-2xl relative z-10 filter grayscale hover:grayscale-0 transition-all duration-700"
      />
    </div>

    {/* Content Container */}
    <div class="reveal delay-200">
      <h2 class="text-4xl font-display font-bold mb-2">About Me.</h2>
      <p
        class="text-gray-400 font-medium text-xs tracking-widest uppercase mb-6"
      >
        WEB DEVELOPER
      </p>

      <p class="text-gray-500 leading-relaxed mb-10 text-lg">
        I am <span class="font-bold text-slate-900">David Nur Hidayat</span> Lorem
        Ipsum is simply dummy text of the printing and typesetting industry. Lorem
        Ipsum has been the industry's standard dummy text ever since the 1500s, when
        an unknown printer took a galley of type and scrambled it to make a type specimen
        book.
      </p>

      <div class="space-y-4 mb-10">
        {
          [
            { label: "Web Design", percentage: 95 },
            { label: "Branding", percentage: 80 },
            { label: "Development", percentage: 90 },
          ].map((skill) => (
            <div class="mb-6">
              <div class="flex justify-between mb-2">
                <span class="text-sm font-semibold tracking-tight uppercase">
                  {skill.label}
                </span>
                <span class="text-sm font-medium">{skill.percentage}%</span>
              </div>
              <div class="h-[6px] w-full bg-gray-100 rounded-full overflow-hidden shadow-inner">
                <div
                  class="skill-progress h-full bg-slate-900 rounded-full transition-all duration-1000 ease-out"
                  style={`width: 0%`}
                  data-target={skill.percentage}
                />
              </div>
            </div>
          ))
        }
      </div>

      <div class="flex space-x-4">
        <a
          href="/public/CV_David_Nur_Hidayat.pdf"
          download
          class="px-8 py-3 bg-slate-900 text-white font-semibold text-sm rounded shadow-lg transition-transform hover:-translate-y-1 inline-block"
        >
          Download C.V
        </a>
        <button
          class="px-8 py-3 bg-white text-slate-900 border border-gray-200 font-semibold text-sm rounded transition-all hover:bg-slate-50"
        >
          Contact Me
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const bars = entry.target.querySelectorAll(".skill-progress");
          bars.forEach((bar) => {
            const target = bar.getAttribute("data-target");
            (bar as HTMLElement).style.width = target + "%";
          });
        }
      });
    },
    { threshold: 0.5 },
  );

  document.addEventListener("DOMContentLoaded", () => {
    const section = document.getElementById("about");
    if (section) observer.observe(section);
  });
</script>
