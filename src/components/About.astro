---
import { Icon } from "astro-icon/components";

const skills = [
  {
    name: "Laravel",
    icon: "logos:laravel",
  },
  {
    name: "Vue.js",
    icon: "logos:vue",
  },
  {
    name: "Astro.js",
    icon: "logos:astro-icon",
  },
  {
    name: "Tailwind CSS",
    icon: "logos:tailwindcss-icon",
  },
  {
    name: "JavaScript",
    icon: "logos:javascript",
  },
  {
    name: "PHP",
    icon: "logos:php",
  },
  {
    name: "MySQL",
    icon: "logos:mysql",
  },
  {
    name: "REST API",
    icon: "carbon:api",
  },
  {
    name: "GitHub",
    icon: "logos:github-icon",
  },
];
---

<section id="about" class="py-40 relative">
  <div class="max-w-7xl mx-auto px-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-24">
      <!-- Bio -->
      <div class="reveal">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-8 h-[1px] bg-[#ff2b2b]"></div>
          <h2
            class="text-[#ff2b2b] font-bold tracking-[0.3em] uppercase text-[11px]"
          >
            About Me
          </h2>
        </div>
        <h3
          class="text-5xl md:text-6xl font-black tracking-tighter mb-10 dark:text-white text-black leading-tight"
        >
          I BUILD <br /> MODERN WEB <br /> SOLUTIONS.
        </h3>
        <p class="text-xl opacity-60 leading-relaxed mb-8 font-light italic">
          "Simple design creates better experiences."
        </p>
        <p class="text-lg opacity-60 leading-relaxed mb-8">
          I am a web developer focused on building modern, responsive, and
          user-friendly web applications. I enjoy creating clean digital
          experiences using Laravel, Vue.js, Astro.js, and Tailwind CSS.
        </p>
      </div>

      <!-- Stats & Skills -->
      <div class="space-y-16">
        <!-- Skills -->
        <div class="reveal delay-300">
          <p
            class="text-[10px] font-bold tracking-[0.4em] uppercase opacity-30 mb-8"
          >
            SELECTED TECH STACK
          </p>

          <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
            {
              skills.map((skill) => (
                <div class="grayscale hover:grayscale-0 group relative overflow-hidden border border-white/5 bg-white/[0.02] backdrop-blur-sm rounded-2xl p-6 flex flex-col items-center justify-center gap-4 hover:border-[#ff2b2b]/40 hover:bg-[#ff2b2b]/5 transition-all duration-500">
                  {/* Glow */}
                  <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition duration-500 bg-gradient-to-br from-[#ff2b2b]/10 via-transparent to-transparent" />

                  {/* Icon */}
                  <Icon
                    name={skill.icon}
                    class="w-14 h-14 relative z-10 transition-transform duration-500 group-hover:scale-110 "
                  />

                  {/* Text */}
                  <span class="relative z-10 text-sm font-semibold tracking-wide dark:text-white text-black opacity-70 group-hover:opacity-100 transition">
                    {skill.name}
                  </span>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
