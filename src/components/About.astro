---
const skills = [
  { name: "Pr", color: "bg-[#00005b]" },
  { name: "Ai", color: "bg-[#330000]" },
  { name: "Ps", color: "bg-[#001e36]" },
  { name: "Lr", color: "bg-[#001e36]" },
  { name: "Canva", color: "bg-[#00c4cc]" },
  { name: "Figma", color: "bg-black" },
  { name: "CapCut", color: "bg-sky-500" },
  { name: "Mobile", color: "bg-red-500" },
];
---

<section
  class="relative w-full border-t border-text/10 bg-bg px-6 py-24 md:px-12 lg:px-24"
>
  <div class="grid grid-cols-1 gap-16 lg:grid-cols-12">
    <!-- Left: Photo & Table of content label -->
    <div class="lg:col-span-4">
      <div class="flex items-center gap-4 mb-8">
        <span class="font-display text-xl uppercase">About</span>
        <div class="h-[1px] flex-grow bg-text/20"></div>
        <div
          class="flex h-8 w-8 items-center justify-center rounded-full border border-text text-sm"
        >
          &gt;
        </div>
      </div>

      <div class="relative inline-block w-full">
        <!-- Photo with yellow border effect -->
        <div
          class="aspect-[4/5] overflow-hidden grayscale border-8 border-primary brutal-shadow"
        >
          <img
            src="/profile2.jpg"
            alt="About Randy"
            class="h-full w-full object-cover"
          />
        </div>
      </div>

      <!-- Contact Info -->
      <div
        class="mt-12 bg-primary p-6 brutal-border brutal-shadow flex flex-col md:flex-row gap-6 items-center"
      >
        <div class="w-32 h-32 bg-white p-2 brutal-border">
          <!-- QR Code Placeholder -->
          <div class="w-full h-full bg-text flex items-center justify-center">
            <div class="w-24 h-24 bg-white grid grid-cols-4 grid-rows-4 p-1">
              <div class="bg-text"></div><div></div><div class="bg-text">
              </div><div></div>
              <div></div><div class="bg-text"></div><div></div><div
                class="bg-text"
              >
              </div>
              <div class="bg-text"></div><div></div><div class="bg-text">
              </div><div></div>
              <div></div><div class="bg-text"></div><div></div><div
                class="bg-text"
              >
              </div>
            </div>
          </div>
        </div>
        <div class="flex-grow">
          <h3
            class="font-display text-xl uppercase underline decoration-2 underline-offset-4 mb-4"
          >
            Let's Work Together :
          </h3>
          <ul class="space-y-3 font-accent text-sm font-semibold">
            <li class="flex items-start gap-3">
              <span
                class="mt-1 flex h-6 w-6 items-center justify-center border border-black rounded-sm text-[10px]"
                >EMAIL</span
              >
              <span>randyfahmi902@gmail.com</span>
            </li>
            <li class="flex items-start gap-3">
              <span
                class="mt-1 flex h-6 w-6 items-center justify-center border border-black rounded-sm text-[10px]"
                >WA</span
              >
              <span>+62 8223 4498 123</span>
            </li>
            <li class="flex items-start gap-3">
              <span
                class="mt-1 flex h-6 w-6 items-center justify-center border border-black rounded-sm text-[10px]"
                >IG</span
              >
              <span>@randy_fahmi</span>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Right: Bio & Skills -->
    <div class="lg:col-span-8 relative">
      <!-- Big "02" background -->
      <div
        class="absolute -right-20 top-20 -z-10 font-display text-[15rem] leading-none text-text/5 md:text-[20rem]"
      >
        02
      </div>

      <div class="flex items-center gap-4 mb-8">
        <div class="h-[1px] flex-grow bg-text/20"></div>
        <div
          class="flex h-8 w-8 items-center justify-center rounded-full border border-text text-sm"
        >
          &gt;
        </div>
      </div>

      <div class="relative mb-12">
        <span
          class="absolute -left-10 -top-4 text-4xl font-display text-primary"
          >"</span
        >
        <h2 class="font-display text-7xl uppercase tracking-tighter text-text">
          HELLO<span class="text-primary">.</span>
        </h2>
        <div
          class="mt-8 max-w-2xl space-y-4 font-accent text-lg leading-relaxed text-text/80"
        >
          <p>
            I'm <span
              class="font-bold text-text underline decoration-primary decoration-4"
              >David Nur Hidayat</span
            >, a self-taught graphic designer & IT with over 9 years of
            experience. I love creating visuals that don't just look good - they
            tell a story. From social media content to brochures and billboards,
            I enjoy bringing ideas to life.
          </p>
          <p>
            I also explore photography and videography to add more depth to my
            work. For me, design is all about connecting ideas with people in a
            creative way.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <!-- Education -->
        <div>
          <h3
            class="font-display text-2xl uppercase underline decoration-primary decoration-4 underline-offset-8 mb-6"
          >
            Education
          </h3>
          <div class="flex gap-4">
            <div class="flex flex-col items-center">
              <span class="font-display text-sm">2012-</span>
              <span class="font-display text-2xl">2015</span>
            </div>
            <div>
              <h4 class="text-xl font-bold uppercase">
                Informatics Engineering
              </h4>
              <p class="text-sm font-accent text-text/60 italic">
                Academy of Information Management and Computer Jember
              </p>
              <p class="text-xs font-accent text-text/40 mt-1 uppercase">
                Muhammadiyah University of Jember
              </p>
            </div>
          </div>
        </div>

        <!-- Software Skills -->
        <div>
          <h3
            class="font-display text-2xl uppercase underline decoration-primary decoration-4 underline-offset-8 mb-6"
          >
            Software Skill
          </h3>
          <div class="grid grid-cols-4 gap-3">
            {
              skills.map((skill) => (
                <div
                  class={`${skill.color} aspect-square flex items-center justify-center rounded-md border-2 border-text brutal-shadow`}
                >
                  <span class="font-display text-xs text-white uppercase">
                    {skill.name}
                  </span>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <!-- Experience Section -->
      <div class="mt-16">
        <h3
          class="font-display text-2xl uppercase underline decoration-primary decoration-4 underline-offset-8 mb-8"
        >
          Working Experience
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8">
          <div>
            <h4 class="font-bold text-lg uppercase">IT Staff</h4>
            <p class="text-sm italic font-accent">
              PT. Evolusi Teknologi Indonesia
            </p>
            <p class="text-xs font-accent text-text/40 mt-1 uppercase">
              May 2015 - May 2017
            </p>
          </div>
          <div>
            <h4 class="font-bold text-lg uppercase">Graphic Design</h4>
            <p class="text-sm italic font-accent">Jember Mini Zoo</p>
            <p class="text-xs font-accent text-text/40 mt-1 uppercase">
              October 2020 - August 2022
            </p>
          </div>
          <div>
            <h4 class="font-bold text-lg uppercase">IT Staff</h4>
            <p class="text-sm italic font-accent">PT. Lippo Malls Indonesia</p>
            <p class="text-xs font-accent text-text/40 mt-1 uppercase">
              May 2017 - December 2018
            </p>
          </div>
          <div>
            <h4 class="font-bold text-lg uppercase">
              Graphic Design & Content Creator
            </h4>
            <p class="text-sm italic font-accent">PT. Sepokat Menjala Berkah</p>
            <p class="text-xs font-accent text-text/40 mt-1 uppercase">
              August 2022 - June 2024
            </p>
          </div>
          <div>
            <h4 class="font-bold text-lg uppercase">
              IT Supervisor & Graphic Design
            </h4>
            <p class="text-sm italic font-accent">
              Swiss-Belhotel Kemayoran - Jakarta
            </p>
            <p class="text-xs font-accent text-text/40 mt-1 uppercase">
              January 2019 - September 2020
            </p>
          </div>
          <div>
            <h4 class="font-bold text-lg uppercase">
              IT & Graphic Design (Freelance)
            </h4>
            <p class="text-xs font-accent text-text/40 mt-1 uppercase">
              2018 - Present
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
