---
// Services.astro
const services = [
  { icon: "laptop", title: "Web Design" },
  { icon: "megaphone", title: "Branding" },
  { icon: "umbrella", title: "Development" },
  { icon: "palette", title: "Creative Design" },
  { icon: "smartphone", title: "Fully Responsive" },
  { icon: "camera", title: "Retina Ready" },
];

const getIcon = (name: string) => {
  // Simple icon map for clean code
  switch (name) {
    case "laptop":
      return '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 16V8a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v8"/><path d="M4 16h16"/><path d="M22 20H2a2 2 0 0 1-2-2v-1h24v1a2 2 0 0 1-2 2Z"/></svg>';
    case "megaphone":
      return '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m3 11 18-5v12L3 14v-3z"/><path d="M11.6 16.8 a3 3 0 1 1 -5.8 -0.8"/></svg>';
    case "umbrella":
      return '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12a10 10 0 1 0-20 0Z"/><path d="M12 12v8"/><path d="M12 20a2 2 0 1 0 4 0"/></svg>';
    case "palette":
      return '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r=".5"/><circle cx="17.5" cy="10.5" r=".5"/><circle cx="8.5" cy="7.5" r=".5"/><circle cx="6.5" cy="12.5" r=".5"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.9 0 1.6-.7 1.6-1.6 0-.4-.2-.8-.4-1.1s-.4-.7-.4-1.1c0-.9.7-1.6 1.6-1.6h2.8c4.4 0 8-3.6 8-8 0-4.4-3.6-8-8-8z"/></svg>';
    case "smartphone":
      return '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>';
    case "camera":
      return '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>';
    default:
      return "";
  }
};
---

<section id="services" class="py-24 bg-gray-50/50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="reveal text-center mb-20">
      <h2
        class="text-4xl font-display font-black tracking-tight relative inline-block"
      >
        Services.
        <div class="absolute -bottom-2 left-0 w-full h-[3px] bg-slate-900/10">
        </div>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        services.map((service, index) => (
          <div
            class="reveal bg-white p-12 text-center shadow-[0_0_40px_rgba(0,0,0,0.03)] border border-gray-50 flex flex-col items-center group transition-all hover:shadow-xl hover:-translate-y-2 rounded-sm"
            style={`transition-delay: ${index * 100}ms`}
          >
            <div class="w-16 h-16 bg-gray-50 rounded-full flex items-center justify-center mb-8 transition-colors group-hover:bg-slate-900 group-hover:text-white">
              <Fragment set:html={getIcon(service.icon)} />
            </div>
            <h3 class="text-xl font-display font-bold mb-4">{service.title}</h3>
            <p class="text-gray-400 text-sm leading-relaxed">
              Lorem Ipsum is simply dummy text of the Lorem Ipsum has been the
              industry's standard dummy text ever
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
