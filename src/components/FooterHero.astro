---
const categories = [
  { 
    title: 'Graphic Design', 
    icon: 'M12 19l7-7 3 3-7 7-3-3z M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z' 
  },
  { 
    title: 'Photographer', 
    icon: 'M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z M12 17a4 4 0 1 0 0-8 4 4 0 0 0 0 8z' 
  },
  { 
    title: 'Videographer', 
    icon: 'M23 7l-7 5 7 5V7z M1 5h11a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H1a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2z' 
  },
  { 
    title: 'Video & Photo Editor', 
    icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z' 
  }
];
---
<section class="relative w-full overflow-hidden bg-bg px-6 py-32 md:px-12 lg:px-24">
  <div class="flex items-center gap-4 mb-16">
    <span class="font-display text-xl uppercase">Table Of Content</span>
    <div class="h-[1px] flex-grow bg-text/20"></div>
    <div class="flex h-8 w-8 items-center justify-center rounded-full border border-text text-sm">&gt;</div>
  </div>

  <div class="relative flex justify-center">
    <!-- Massive Outline Text "TABLE OF CONTENT" -->
    <div class="absolute inset-0 top-1/2 flex -translate-y-1/2 select-none items-center justify-center pointer-events-none">
       <span class="font-display text-[8rem] md:text-[15rem] leading-none opacity-5 uppercase italic tracking-tighter" style="-webkit-text-stroke: 2px black; color: transparent;">
         TABLE OF <span class="text-text opacity-100 italic" style="-webkit-text-stroke: 0px">CONTENT</span> ENT.
       </span>
    </div>

    <!-- Cards Container -->
    <div class="relative z-10 grid w-full grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {categories.map(cat => (
        <div class="group relative flex flex-col items-center">
           <div class="w-full aspect-[4/3] bg-primary rounded-[2rem] border-4 border-text brutal-shadow flex items-center justify-center group-hover:-translate-y-2 transition-transform duration-300">
              <svg 
                xmlns="http://www.w3.org/2000/svg" 
                viewBox="0 0 24 24" 
                fill="none" 
                stroke="currentColor" 
                stroke-width="2" 
                stroke-linecap="round" 
                stroke-linejoin="round" 
                class="w-20 h-20 text-white"
              >
                <path d={cat.icon} />
              </svg>
           </div>
           
           <div class="mt-6 font-display text-lg uppercase tracking-tight text-center">
             {cat.title}
           </div>
           
           <!-- Decorative dotted line on right (only for md and up, and not last) -->
           <div class="hidden md:block absolute -right-4 top-1/2 -translate-y-1/2 w-8 h-[2px] border-b-2 border-dotted border-text/20 last:hidden"></div>
        </div>
      ))}
    </div>
  </div>
  
  <!-- Right Vertical Text -->
  <div class="absolute -right-12 top-1/2 rotate-90 whitespace-nowrap font-accent text-xs font-bold uppercase tracking-[0.2em] text-text/40">
    DAVID &copy; 2026
  </div>
</section>
